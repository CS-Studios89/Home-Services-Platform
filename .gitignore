# Private environment files
**/.env
**/.env.*
!.env.example

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/
**/.next/
**/out/

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage
**/coverage/

# Cache files
**/.cache/
**/.parcel-cache/
**/.vite/
**/.eslintcache

# OS / Editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temporary files
**/*.tmp
**/*.temp

# React environment local overrides
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Backend uploads or generated files if needed
**/uploads/
**/tmp/

# Optional lock for runtime process managers
**/.pid
**/.pid.lock